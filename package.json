{
  "name": "InOut",
  "version": "0.1.0",
  "private": true,
  "description": "InOut - Smart attendance SaaS for small businesses",
  "workspaces": ["apps/web", "apps/api"],
  "scripts": {
    "dev:web": "npm --workspace apps/web run start",
    "dev:api": "npm --workspace apps/api run start:dev",
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "prisma:migrate": "npm --workspace apps/api run prisma:migrate",
    "prisma:studio": "npm --workspace apps/api run prisma:studio"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
